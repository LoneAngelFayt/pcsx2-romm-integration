#!/usr/bin/with-contenv bash

echo "[broker-mod] Checking for Python3..."
if ! command -v python3 &> /dev/null; then
    echo "[broker-mod] Python3 not found. Installing..."
    apt-get update -qq && apt-get install -y -qq python3
else
    echo "[broker-mod] Python3 already installed: $(python3 --version)"
fi

echo "[broker-mod] Symlinking BIOS directory..."
# PCSX2 defaults to /config/.config/PCSX2/bios but compose mounts BIOS at /config/bios
mkdir -p /config/.config/PCSX2
chown abc:abc /config/.config/PCSX2
if [ ! -e /config/.config/PCSX2/bios ]; then
    ln -s /config/bios /config/.config/PCSX2/bios
fi

echo "[broker-mod] Waiting for PCSX2.ini..."
INI="/config/.config/PCSX2/inis/PCSX2.ini"
for i in $(seq 1 60); do
    if [ -f "$INI" ]; then
        echo "[broker-mod] Patching PCSX2.ini..."

        # Enable PINE IPC
        sed -i 's/EnablePINE = false/EnablePINE = true/' "$INI"

        # Fix BIOS path to absolute container path
        sed -i 's|^Bios = .*|Bios = /config/bios|' "$INI"

        # PCSX2 writes relative paths here on exit; pin them to absolute
        sed -i 's|^Savestates = .*|Savestates = /config/.config/PCSX2/sstates|' "$INI"
        sed -i 's|^MemoryCards = .*|MemoryCards = /config/.config/PCSX2/memcards|' "$INI"

        echo "[broker-mod] PCSX2.ini patched:"
        grep -E "EnablePINE|Bios " "$INI"
        break
    fi
    sleep 2
done

echo "[broker-mod] Fixing XDG_RUNTIME_DIR permissions..."
chmod 700 /config/.XDG

echo "[broker-mod] Setting broker.py and launcher executable..."
chmod +x /root/broker.py
chmod 755 /usr/local/bin/pcsx2-launcher.sh

echo "[broker-mod] Writing labwc autostart..."
AUTOSTART="/config/.config/labwc/autostart"
mkdir -p "$(dirname "$AUTOSTART")"
cat > "$AUTOSTART" << 'AUTOSTART_EOF'
#!/bin/bash
PIDFILE=/tmp/pcsx2-autostart.pid

# Kill any orphaned autostart loop left over from a previous labwc session
if [ -f "$PIDFILE" ]; then
    OLD_PID=$(cat "$PIDFILE")
    if [ "$OLD_PID" != "$$" ] && kill -0 "$OLD_PID" 2>/dev/null; then
        kill "$OLD_PID" 2>/dev/null
        pkill -P "$OLD_PID" 2>/dev/null
    fi
fi
echo $$ > "$PIDFILE"

export WAYLAND_DISPLAY=wayland-1
export XDG_RUNTIME_DIR=/config/.XDG
while true; do
    foot -e /usr/local/bin/pcsx2-launcher.sh
    sleep 1
done
AUTOSTART_EOF
chmod +x "$AUTOSTART"

echo "[broker-mod] Starting broker.py..."
exec python3 -u /root/broker.py