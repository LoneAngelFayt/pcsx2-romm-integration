#!/usr/bin/with-contenv bash
# Runs via init-custom-files, before init-services, so dirs exist before PCSX2 starts.

echo "[broker-mod] Creating PCSX2 config directories..."
mkdir -p /config/.config/PCSX2
chown abc:abc /config/.config /config/.config/PCSX2

echo "[broker-mod] Symlinking BIOS directory..."
# PCSX2 defaults to /config/.config/PCSX2/bios but compose mounts BIOS at /config/bios.
# If PCSX2 already created an empty bios dir on a prior run, replace it with the symlink.
if [ -d /config/.config/PCSX2/bios ] && [ -z "$(ls -A /config/.config/PCSX2/bios 2>/dev/null)" ]; then
    rmdir /config/.config/PCSX2/bios
fi
if [ ! -e /config/.config/PCSX2/bios ]; then
    ln -s /config/bios /config/.config/PCSX2/bios
fi

echo "[broker-mod] Fixing XDG_RUNTIME_DIR permissions..."
mkdir -p /config/.XDG
chmod 700 /config/.XDG
